# ===========================================
# ShopEase Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# Django Core Settings
# -------------------------------------------

# Django settings module: config.settings.development | config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

# Secret key for cryptographic signing (required in production)
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here

# Comma-separated list of allowed hostnames
# Example: shop-api.onrender.com,localhost,127.0.0.1
ALLOWED_HOSTS=*

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# Development uses MySQL, production uses PostgreSQL via DATABASE_URL

# MySQL (Development)
DB_NAME=shop
DB_USER=root
DB_PASSWORD=123456
DB_HOST=127.0.0.1
DB_PORT=3306

# PostgreSQL (Production) - full connection URL
# Format: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
# Comma-separated list of allowed frontend origins
# Example: https://shop-xxx.vercel.app,http://localhost:5173
CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

# -------------------------------------------
# Alipay Configuration
# -------------------------------------------
# Sandbox defaults are provided; override for production

ALIPAY_APPID=9021000163699686
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=

# -------------------------------------------
# WeChat Pay Configuration (Optional)
# -------------------------------------------
# Uncomment and configure for WeChat Pay integration

# WECHAT_PAY_APPID=
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# WECHAT_PAY_NOTIFY_URL=
# WECHAT_PAY_SANDBOX=true
