# ===========================================
# ShopEase Frontend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# API Configuration
# -------------------------------------------

# Backend API base URL for production build
# In development, Vite proxy handles /api/* → http://127.0.0.1:8000/api/*
VITE_API_BASE=https://shop-api-xxx.onrender.com/api/v1

# -------------------------------------------
# Development Proxy Target (Optional)
# -------------------------------------------
# Override the default backend URL for local development
# Default: http://127.0.0.1:8000
VITE_PROXY_TARGET=http://127.0.0.1:8000
